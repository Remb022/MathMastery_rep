<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".MainActivity">

    <!-- Header -->
    <include
        android:id="@+id/header"
        layout="@layout/header_component"/>

    <!-- Body -->
    <ScrollView
        android:id="@+id/scrollView3"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/footer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="horizontal">

                <!-- Игра 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/card_game_1"
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 1 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="X + Y = 17"
                        android:textColor="@color/gray"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 18"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

                <View
                    android:layout_width="15dp"
                    android:layout_height="0dp" />

                <!-- Игра 2 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 2 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="2048"
                        android:textColor="@color/gray"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 1387"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="15dp"
                android:orientation="horizontal">

                <!-- Игра 3 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 3 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="&gt; &lt; ="
                        android:textColor="@color/gray"
                        android:textSize="40sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 7"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

                <View
                    android:layout_width="15dp"
                    android:layout_height="0dp" />

                <!-- Игра 4 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 4 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="X ? Y = C"
                        android:textColor="@color/gray"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 37"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="30dp"
                android:orientation="horizontal">

                <!-- Игра 5 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 5 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="X + X = 2X"
                        android:textColor="@color/gray"
                        android:textSize="30sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 3"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

                <View
                    android:layout_width="15dp"
                    android:layout_height="0dp" />

                <!-- Игра 6 -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="250dp"
                    android:layout_weight="1"
                    android:backgroundTint="@color/yalow"
                    app:cardCornerRadius="7dp"
                    app:cardElevation="2dp"
                    app:cardUseCompatPadding="true">

                    <!-- Информация игра 6 -->
                    <ImageButton
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_margin="8dp"
                        android:background="@android:color/transparent"
                        android:src="@drawable/info_icon" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="\?"
                        android:textColor="@color/gray"
                        android:textSize="70sp"
                        android:textStyle="bold" />

                    <!-- Рекорд -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="10dp"
                        android:text="рекорд: 18"
                        android:textColor="@color/gray"
                        android:textSize="20sp" />

                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Footer -->
    <include
        layout="@layout/footer_component"
        android:id="@+id/footer" />

</androidx.constraintlayout.widget.ConstraintLayout>